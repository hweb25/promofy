{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Web Dashboard",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "web-dashboard"
    },
    {
      "name": "Flutter Mobile (Web Mode)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "web-server", "--web-port", "8080"],
      "port": 8080,
      "cwd": "mobile"
    },
    {
      "name": "Supabase Local",
      "runtimeExecutable": "supabase",
      "runtimeArgs": ["start"],
      "port": 54321,
      "cwd": "."
    }
  ]
}
